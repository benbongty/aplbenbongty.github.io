{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User preferences and AtCoder username",
      "type": "object",
      "properties": {
        "atcoderUsername": { "type": "string", "description": "The user's mapped AtCoder username" },
        "selectedColors": { "type": "array", "items": { "type": "string" }, "description": "Selected difficulty colors" },
        "minRating": { "type": "number", "description": "min rating search" },
        "maxRating": { "type": "number", "description": "max rating search" },
        "todoList": { "type": "array", "items": { "type": "string" }, "description": "List of problem IDs to solve" },
        "updatedAt": { "type": "number", "description": "Update timestamp" }
      },
      "required": ["atcoderUsername", "selectedColors", "todoList", "updatedAt"]
    },
    "CustomList": {
      "title": "CustomList",
      "description": "A custom problemset list created by the user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "problems": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "problems", "updatedAt"]
    },
    "CalendarNote": {
      "title": "CalendarNote",
      "description": "A daily note on the calendar",
      "type": "object",
      "properties": {
        "note": { "type": "string", "description": "The note content" },
        "updatedAt": { "type": "number" }
      },
      "required": ["note", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Store user's central profile and preferences"
    },
    "/users/{userId}/customLists/{listId}": {
      "schema": { "$ref": "#/entities/CustomList" },
      "description": "Store user's custom created lists"
    },
    "/users/{userId}/calendarNotes/{dateString}": {
      "schema": { "$ref": "#/entities/CalendarNote" },
      "description": "Store notes attached to local date string (YYYY-MM-DD)"
    }
  }
}
