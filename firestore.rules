rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidStrList(arr, maxSize) {
      return arr is list && arr.size() <= maxSize && (arr.size() == 0 || arr[0] is string);
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['atcoderUsername', 'selectedColors', 'minRating', 'maxRating', 'todoList', 'updatedAt']) &&
             data.size() == 6 &&
             data.atcoderUsername is string && data.atcoderUsername.size() <= 100 &&
             isValidStrList(data.selectedColors, 20) &&
             (data.minRating == null || (data.minRating is number)) &&
             (data.maxRating == null || (data.maxRating is number)) &&
             isValidStrList(data.todoList, 1500) &&
             data.updatedAt == request.time;
    }

    function isValidCustomList(data) {
      return data.keys().hasAll(['name', 'problems', 'updatedAt']) &&
             data.size() == 3 &&
             data.name is string && data.name.size() <= 150 &&
             isValidStrList(data.problems, 2000) &&
             data.updatedAt == request.time;
    }

    function isValidCalendarNote(data) {
      return data.keys().hasAll(['note', 'updatedAt']) &&
             data.size() == 2 &&
             data.note is string && data.note.size() <= 6000 &&
             data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUserProfile(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUserProfile(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['atcoderUsername', 'selectedColors', 'minRating', 'maxRating', 'todoList', 'updatedAt'])
      );
      
      match /customLists/{listId} {
        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(listId) && isValidCustomList(incoming());
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(listId) && isValidCustomList(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'problems', 'updatedAt'])
        );
        allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(listId);
      }

      match /calendarNotes/{dateString} {
        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(dateString) && isValidCalendarNote(incoming());
        allow update: if isSignedIn() && request.auth.uid == userId && isValidId(dateString) && isValidCalendarNote(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['note', 'updatedAt'])
        );
        allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(dateString);
      }
    }
  }
}
